{
  "manifest_version": 3,
  "name": "YouTube Snapshot",
  "version": "1.3.3",
  "description": "Take snapshots of YouTube videos and save to clipboard or file.",
  "permissions": ["storage", "webNavigation", "scripting", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.youtube-nocookie.com/*"],
      "js": ["js/libs/gif-recorder.js", "js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/snapshot-icon.png",
        "audio/download-sound.mp3"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
